CompileFlags:
  Add: [-Wall, -Wextra, -Wpedantic, -O0, -std=c++20, -fshort-wchar, -c, -DDEBUG, -D_DEBUG, -I./include, -I/usr/include/qt6]
  Compiler:  clang.exe
  CompilationDatabase: None

Completion:
  AllScopes: Yes

Index:
  Background: Skip

InlayHints:
  BlockEnd: Yes
  Designators: Yes
  Enabled: Yes
  ParameterNames: Yes
  DeducedTypes: Yes
  TypeNameLimit: 0

Hover:
  ShowAKA: Yes

Diagnostics:
  ClangTidy:
    FastCheckFilter: None
