QSlider::groove:horizontal {
    background: red;
    position: absolute;
    left: 4px;
    right: 4px;
}

QSlider::handle:horizontal {
    height: 10px;
    background: green;
    margin: 0 -4px;
    border: 1px solid;
    border-radius: 3px;
}

QSlider::add-page:horizontal {
    background: white;
}

QSlider::sub-page:horizontal {
    background: pink;
}
